# Banco de dados PostgreSQL na VPS
DATABASE_URL="postgresql://user:password@host:5432/mototrack?schema=public"
TZ=America/Sao_Paulo
PGTZ=America/Sao_Paulo

# JWT — gerar chaves fortes com: openssl rand -base64 64
JWT_SECRET=troque_por_uma_chave_secreta_longa_aqui
JWT_EXPIRES_IN=10h
JWT_REFRESH_SECRET=troque_por_outra_chave_secreta_aqui
JWT_REFRESH_EXPIRES_IN=7d

# Servidor
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://seudominio.com.br
CORS_ORIGIN=https://seudominio.com.br
LOG_LEVEL=info

# MinIO (storage de fotos de comprovante)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=chave_de_acesso
MINIO_SECRET_KEY=chave_secreta
MINIO_BUCKET=mototrack
